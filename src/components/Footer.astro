---
import Il from '../components/InnerLink.astro'
import Ol from '../components/OuterLink.astro'
---

<footer class="mx-6 my-12 flex justify-center gap-6">
  <img class="max-w-32 h-auto object-contain rounded-2xl" src="/portrait-beat-2026.jpg" />
  <div class="flex justify-center text-center flex-col gap-2">
    <p class="font-light font-sans f-text-xs text-zinc-400 italic">
      Written by a human, all <Ol href="https://practicaltypography.com/hyphens-and-dashes.html"
        >en and em dashes my own</Ol
      >.
    </p>
    <p class="font-light font-sans f-text-xs text-zinc-400 italic">
      Thought of something you want to share with me?<br />
      Please <Il href="contacting-me">tell me about it</Il>—I read every message.
    </p>
  </div>
</footer>
