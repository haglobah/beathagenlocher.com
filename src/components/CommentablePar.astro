---
import CommentButton from './CommentButton.tsx'
---

<span class="commentable-par inline group relative">
  <p class="f-my-lg max-w-[65ch] rounded transition-background-color duration-200 ease-in-out">
    <slot />
  </p>
  <CommentButton client:idle />
</span>

<style>
  .commentable-par.comment-active > p {
    background-color: rgba(100, 108, 255, 0.08);
  }
</style>
